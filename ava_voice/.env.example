# Ava Voice — example environment configuration.
# Copy to `.env` and adjust. All variables are optional; defaults are shown.

# --- Application ---
AVA_APP_NAME=Ava Voice
AVA_ENVIRONMENT=development          # development | staging | production | test
AVA_DEBUG=false

# --- HTTP server ---
AVA_HOST=0.0.0.0
AVA_PORT=8000
AVA_API_PREFIX=/api/v1

# --- Logging ---
AVA_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
AVA_LOG_DIR=logs
AVA_LOG_JSON=false

# --- Model paths (prefix: AVA_MODEL_) ---
AVA_MODEL_ROOT_DIR=models
AVA_MODEL_TTS_DIR=models/tts
AVA_MODEL_EMOTION_DIR=models/emotion
AVA_MODEL_CLONE_DIR=models/clone
AVA_MODEL_DEVICE=auto                # cpu | cuda | mps | auto

# --- Redis (prefix: AVA_REDIS_) ---
AVA_REDIS_HOST=localhost
AVA_REDIS_PORT=6379
AVA_REDIS_DB=0
AVA_REDIS_PASSWORD=
AVA_REDIS_SSL=false
AVA_REDIS_DEFAULT_TTL_SECONDS=3600

# --- WebSocket (prefix: AVA_WS_) ---
AVA_WS_PATH=/ws/stream
AVA_WS_HEARTBEAT_INTERVAL_SECONDS=20
AVA_WS_MAX_MESSAGE_BYTES=1048576
AVA_WS_MAX_CONNECTIONS=1024
AVA_WS_RECEIVE_TIMEOUT_SECONDS=60
